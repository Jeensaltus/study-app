# Server-only keys — NOT bundled into the browser (safe for deploy).
# Local: npm run dev / npm start
# Vercel: Project Settings → Environment Variables

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=

# --- Vercel deploy (AI + Google Drive KB, no PDF on server) ---
#   VITE_KB_SOURCE=external
#   GEMINI_API_KEY=...
#   NVIDIA_API_KEY=...
# Root Directory in Vercel: study-app
#
# VITE_KB_SOURCE: local | external | both
#   local    = PDF จาก subject/ (dev)
#   external = ลิงก์ Google Drive ใน knowledgeBaseExternal.js
#   both     = ทั้งสองแบบ
